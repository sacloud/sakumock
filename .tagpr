[tagpr]
	releaseBranch = main
	versionFile = cmd/sakumock/version.go
	vPrefix = true
	# The unified binary uses bare version tags (vX.Y.Z, no tagPrefix). The
	# per-service modules keep their own prefixed tags via .github/workflows/tagpr.yml.
	# tagpr creates the GitHub Release with auto-generated notes (categorized via
	# .github/release.yml); GoReleaser then uploads the binaries to that release
	# with release.mode=keep-existing, leaving the notes intact
	# (see .github/workflows/release.yml and .goreleaser.yaml).
	release = true
	majorLabels = sacloud-major
	minorLabels = sacloud-minor
	changelogFile = CHANGELOG.md
