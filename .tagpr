[tagpr]
	releaseBranch = main
	versionFile = version.go
	vPrefix = true
	# The repository is a single Go module released as one unit with bare
	# version tags (vX.Y.Z). Historical per-service tags (e.g. kms/v0.1.0)
	# predate the module consolidation.
	# tagpr creates the GitHub Release as a DRAFT with auto-generated notes
	# (categorized via .github/release.yml); GoReleaser then uploads the binaries
	# to that release with release.mode=keep-existing and publishes it. A draft
	# must be used because GitHub immutable releases freeze a published release's
	# assets — uploading after publish fails with 422, so we attach assets while
	# it is still a draft and publish last (see .github/workflows/release.yml and
	# .goreleaser.yaml).
	release = draft
	majorLabels = sacloud-major
	minorLabels = sacloud-minor
	changelogFile = CHANGELOG.md
